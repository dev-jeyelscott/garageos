{
  "name": "garageos",
  "private": true,
  "version": "0.0.0",
  "description": "GarageOS - Motorcycle Shop Management System SaaS",
  "packageManager": "pnpm@11.9.0",
  "scripts": {
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:watch": "pnpm -r test:watch",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "audit:deps": "pnpm audit --audit-level high",
    "milestone:check": "pnpm format && pnpm lint && pnpm  typecheck && pnpm test",
    "db:migrate:validate": "echo \"Migration validation placeholder: no migrations exist yet. Replace in Milestone 1.\"",
    "dev:web": "pnpm --filter @garageos/web dev",
    "dev:api": "pnpm --filter @garageos/api dev",
    "dev:worker": "pnpm --filter @garageos/worker dev",
    "dev:scheduler": "pnpm --filter @garageos/scheduler dev",
    "start:web": "pnpm --filter @garageos/web start",
    "start:api": "pnpm --filter @garageos/api start",
    "start:worker": "pnpm --filter @garageos/worker start",
    "start:scheduler": "pnpm --filter @garageos/scheduler start",
    "dev:db": "docker compose up -d postgres",
    "dev:db:down": "docker compose down",
    "dev:db:reset": "docker compose down -v && docker compose up -d postgres",
    "dev:db:logs": "docker compose logs -f postgres"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,md,yml,yaml}": [
      "prettier --write"
    ],
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix"
    ]
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/coverage-v8": "^4.1.9",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.8.4",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^4.1.9"
  }
}
