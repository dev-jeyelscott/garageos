# GarageOS API environment example
# Copy this file to apps/api/.env for local development.
# Do not commit real .env files.

NODE_ENV=development
PORT=3001

# API
API_BASE_URL=http://localhost:3001
WEB_APP_URL=http://localhost:3000

# PostgreSQL
DATABASE_URL=postgresql://garageos:garageos_dev_password@localhost:5432/garageos_dev

# Auth placeholders only.
# Replace locally with real generated development values in apps/api/.env.
ACCESS_TOKEN_SECRET=replace-with-local-dev-access-token-secret
REFRESH_TOKEN_SECRET=replace-with-local-dev-refresh-token-secret

# Auth Access Token
AUTH_ACCESS_TOKEN_ISSUER=garageos-api
AUTH_ACCESS_TOKEN_AUDIENCE=garageos-pwa
AUTH_ACCESS_TOKEN_SECRET=replace-with-at-least-32-random-characters

# Token policy placeholders aligned to PRD/session requirements.
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30

# Logging
LOG_LEVEL=debug