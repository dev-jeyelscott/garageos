# GarageOS root environment example
# Copy this file to .env for local development.
# Do not commit real .env files.

NODE_ENV=development

# Local PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=garageos_dev
POSTGRES_USER=garageos
POSTGRES_PASSWORD=garageos_dev_password

# Shared database URL for local tooling
DATABASE_URL=postgresql://garageos:garageos_dev_password@localhost:5432/garageos_dev

# Auth Access Token
AUTH_ACCESS_TOKEN_ISSUER=garageos-api
AUTH_ACCESS_TOKEN_AUDIENCE=garageos-pwa
AUTH_ACCESS_TOKEN_SECRET=replace-with-at-least-32-random-characters