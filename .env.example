# GarageOS local development environment example.
# Do not place real secrets in this file.

NODE_ENV=development

# PostgreSQL local defaults
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=garageos
POSTGRES_USER=garageos
POSTGRES_PASSWORD=garageos_dev_password

# Application URLs
WEB_APP_URL=http://localhost:3000
API_BASE_URL=http://localhost:3001/api/v1

# Auth placeholders
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_DAYS=30

# Observability placeholders
LOG_LEVEL=debug
