{
  "name": "@garageos/db",
  "version": "0.0.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "migrate": "node-pg-migrate up --migrations-dir migrations --migrations-table schema_migrations",
    "migrate:down": "node-pg-migrate down --migrations-dir migrations --migrations-table schema_migrations",
    "migrate:create": "node-pg-migrate create --migrations-dir migrations --migration-file-language js",
    "seed": "node ./scripts/seed.cjs",
    "test": "echo \"No db tests yet\""
  },
  "dependencies": {
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "dotenv-cli": "^11.0.0",
    "node-pg-migrate": "^8.0.4"
  }
}
